# ============================================================
# CourseMind environment variables
# ============================================================
# Run `npm run setup` to auto-create the real env files from this
# template (it generates a random AUTH_SECRET for you):
#   - apps/web/.env.local      (used by the Next.js app)
#   - packages/db/.env         (used by Prisma CLI commands)
# NEVER commit the real files — they're gitignored.

# --- Database ---------------------------------------------------
# Dev default: SQLite file (zero install). The path is relative to
# packages/db/prisma/, so the file lands at packages/db/prisma/dev.db.
# For production Postgres, change packages/db/prisma/schema.prisma
# provider to "postgresql" and set something like:
#   DATABASE_URL="postgresql://user:pass@host:5432/coursemind"
DATABASE_URL="file:./dev.db"

# --- Auth -------------------------------------------------------
# Secret for session JWTs (web) and mobile tokens. `npm run setup`
# generates a strong random value. Keep it secret, keep it stable —
# changing it logs everyone out.
AUTH_SECRET="replace-me-run-npm-run-setup"

# --- AI (the tutor, quiz generation, grading) -------------------
# Get a key at https://console.anthropic.com/settings/keys
# Without it the app still runs: courses, uploads, and the seeded demo
# quiz all work; AI replies show a friendly setup message instead.
ANTHROPIC_API_KEY=""
