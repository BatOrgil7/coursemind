# ============================================================
# CourseMind environment variables
# ============================================================
# Run `npm run setup` to auto-create the real env files from this
# template (it generates a random AUTH_SECRET for you):
#   - apps/web/.env.local      (used by the Next.js app)
#   - packages/db/.env         (used by Prisma CLI commands)
# NEVER commit the real files — they're gitignored.

# --- Database ---------------------------------------------------
# Dev default: SQLite file (zero install). The path is relative to
# packages/db/prisma/, so the file lands at packages/db/prisma/dev.db.
#
# PRODUCTION uses PostgreSQL (the prod schema is generated automatically -
# you do NOT edit schema.prisma). Set DATABASE_URL to your Neon connection
# string in your host's env vars, e.g.:
#   DATABASE_URL="postgresql://user:pass@ep-xxx.neon.tech/neondb?sslmode=require"
# See docs/DEPLOY.md for the full Neon + Vercel walkthrough.
DATABASE_URL="file:./dev.db"

# --- Auth -------------------------------------------------------
# Secret for session JWTs (web) and mobile tokens. `npm run setup`
# generates a strong random value. Keep it secret, keep it stable —
# changing it logs everyone out. In production, generate one with
# `openssl rand -base64 32` and set it in your host's env vars.
AUTH_SECRET="replace-me-run-npm-run-setup"

# Required in production behind a proxy/host (e.g. Vercel) so NextAuth
# trusts the forwarded host. Leave unset locally.
# AUTH_TRUST_HOST="true"

# Google OAuth sign-in (web). Create a Google Cloud OAuth Client ID and
# set the callback URL to:
#   https://your-domain.com/api/auth/callback/google
# Add localhost too if testing locally:
#   http://localhost:3000/api/auth/callback/google
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# --- AI (the tutor, quiz generation, grading) -------------------
# Get a key at https://console.anthropic.com/settings/keys
# Without it the app still runs: courses, materials, and the seeded demo
# quiz all work; AI replies show a friendly setup message instead.
ANTHROPIC_API_KEY=""
