{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "paths": {
      "@/*": [
        "./src/*"
      ],
      "@/assets/*": [
        "./assets/*"
      ],
      "@coursemind/api": [
        "../../packages/api/src"
      ],
      "@coursemind/core": [
        "../../packages/core/src"
      ],
      "@coursemind/db": [
        "../../packages/db/src"
      ]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    ".expo/types/**/*.ts",
    "expo-env.d.ts"
  ]
}
